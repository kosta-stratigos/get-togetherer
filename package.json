{
  "name": "get-togetherer",
  "version": "1.0.0",
  "private": true,
  "description": "A small web app for finding dates that work for a group.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "worker:dev": "wrangler dev",
    "worker:migrate:local": "wrangler d1 migrations apply DB --local",
    "worker:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "worker:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.96.0"
  }
}
